# Salin file ini menjadi .env.local dan isi nilainya.

# Koneksi database PostgreSQL (Neon). Jika kosong, aplikasi otomatis
# fallback ke penyimpanan file JSON lokal (.data/db.json) supaya
# preview Vercel tetap bisa berjalan walau tanpa DB.
DATABASE_URL=

# Kredensial login. Format "username:password,username:password".
# Username "admin" => role ADMIN. Username lain => role SISWA.
# Siswa juga boleh login dengan NIS (5 digit) yang sudah ada di tabel members.
USERS=admin:admin123,guru:guru123,123456:123456,234567:234567

# Secret untuk signing cookie sesi (generate dengan: openssl rand -base64 32)
SESSION_SECRET=ganti-dengan-string-acmin-32-karakter
